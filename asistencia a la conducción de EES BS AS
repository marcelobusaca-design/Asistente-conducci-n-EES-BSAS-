body { font-family: system-ui, sans-serif; background: #fff; }
@keyframes bounce { 0%,80%,100%{transform:scale(.8);opacity:.4} 40%{transform:scale(1.2);opacity:1} }
.dot { width:7px;height:7px;border-radius:50%;background:#999;display:inline-block;margin:0 2px;animation:bounce 1.2s infinite ease-in-out; }
textarea { font-family: system-ui, sans-serif; }
button { font-family: system-ui, sans-serif; }
input { font-family: system-ui, sans-serif; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }
