</head>
<body>
<div id="root"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>

<script>
const { useState, useRef, useEffect } = React;

const COLORS = {
  consultas:"#185FA5", escritos:"#0F6E56", conflictos:"#BA7517",
  criterio:"#7C3AED", archivos:"#533AB7", equipo:"#3B6D11", estudiantes:"#993C1D",
  docente:"#B5460A"
};

const TABS = [
  { id:"consultas",   label:"Consultas",  icon:"💬" },
  { id:"escritos",    label:"Escritos",   icon:"📝" },
  { id:"conflictos",  label:"Conflictos", icon:"⚠️" },
  { id:"criterio",    label:"Criterio",   icon:"⚖️" },
  { id:"archivos",    label:"Archivos",   icon:"📎" },
  { id:"equipo",      label:"Equipo",     icon:"👥" },
  { id:"estudiantes", label:"Alumnos",    icon:"🎒" },
  { id:"docente",     label:"Docente",    icon:"📋" },
];

const ROLES = [
  {id:"director",label:"Director/a"},{id:"vice",label:"Vicedirector/a"},
  {id:"secretaria",label:"Secretaría"},{id:"jefe",label:"Jefe Preceptores"},
  {id:"preceptor",label:"Preceptor/a"},{id:"eoe",label:"EOE"},
  {id:"cite",label:"CITE"},{id:"edte",label:"EDTE"},
  {id:"auxiliar",label:"Auxiliar"},{id:"docente",label:"Docente"},
  {id:"cooperadora",label:"Cooperadora"},
];

const BASE = `Sos un asistente de conducción escolar para escuelas secundarias de la provincia de Buenos Aires. Respondés desde CORRESPONSABILIDAD. Solo respondés cuando tenés certeza basada en normativa DGCyE. Si no sabés, decís que no sabés. Español rioplatense, directo.

CITE = COORDINADOR INSTITUCIONAL DE TRAYECTORIAS EDUCATIVAS (Res.1884/25). Cargo docente individual, 22,5hs, provisional 3 ciclos. NO órgano colegiado. NO puede ser CITE un miembro de conducción.
EDTE = Equipo de Definición de Trayectorias (Res.1650/24 Anexo 2). Órgano colegiado. Estudiantes con más de 4 materias pendientes.
RITE: estados TEA (aprobó), TEP (en proceso), TED (desvinculado).
FORTE = Módulos de intensificación (Res.2624/25). AFTE = Aulas para estudiantes 15-17 años desvinculados (Res.848/22).
AUXILIARES: organismo competente = CONSEJO ESCOLAR (no SAD). Disciplina = LEVE PROBANZA.
Nota mínima: 7. Cuatrimestres NO se promedian. Hasta 5 materias de intensificación.
AIC = Acuerdo Institucional de Convivencia (Res.1650/24 Anexo 6). Vigencia hasta 3 años. CIC = Consejo Institucional de Convivencia.
3 jornadas obligatorias de convivencia por ciclo: marzo-abril, previa a invierno, noviembre-diciembre.
Comunicación Conjunta 1/23: marco vigente para intervención ante conflictos y vulneración de derechos.
CAD 2026: Res.RESOC-2026-275-GDEBA-DGCYE. Inicio 2 marzo, receso 20-31 julio, cierre 22 diciembre. 190 días de clase.
PPI = Proyecto Pedagógico Individual para estudiantes con discapacidad (Res.1664/17).
Centro de Estudiantes: Ley 14581 y 26877. Elecciones 16/9. D'Hont. Mandato 1 año.`;

const PROMPTS = {
  consultas:   BASE,
  escritos:    BASE + "\nGenerás documentos completos: actas, notas a inspección, circulares, comunicaciones, resoluciones. Pedí los datos que necesitás. Formato DGCyE, Arial 12, lenguaje institucional.",
  conflictos:  BASE + "\nEstructurás la respuesta en: 1-CORRESPONSABILIDAD 2-ENCUADRE NORMATIVO 3-PASOS DE INTERVENCIÓN 4-DOCUMENTACIÓN 5-ALERTAS. Ante viralización: silencio institucional → conducción → Inspección → EOE → comunicado sin datos de NNyA → Libro de Actas.",
  criterio:    BASE + "\nAnalizás dilemas éticos y decisiones difíciles de conducción. Presentás opciones con fundamento normativo y consecuencias institucionales. Marco: autoridad pedagógica democrática, corresponsabilidad, derecho irrenunciable a la educación.",
  archivos:    BASE + "\nAnalizás documentos, actas, fotos. Revisás errores, identificás normativa aplicable, sugerís correcciones y mejoras.",
  equipo:      BASE + "\nEspecialidad en roles: Director/a, Vicedirector/a, Secretaría, Jefe Preceptores, Preceptores/as, EOE, CITE (Res.1884/25 — cargo docente individual), EDTE (órgano colegiado), Auxiliares (Ley 10430 — CONSEJO ESCOLAR — LEVE PROBANZA), Cooperadora.",
  estudiantes: BASE + "\nEspecialidad en: trayectorias RITE (TEA/TEP/TED), FORTE, CITE, AIC y convivencia, Centro de Estudiantes (Ley 14581/26877), ESI (Ley 26150), embarazo/maternidad/IVE, discapacidad y PPI, mapa de riesgo y vulneración de derechos.",
  docente:     BASE + `\nEspecialidad en PLANIFICACIÓN DOCENTE para escuelas secundarias de Buenos Aires. Ayudás a construir:

PCP (PLANIFICACIÓN CURRICULAR PEDAGÓGICA):
- Estructura: fundamentación, propósitos, contenidos organizados por unidades o bloques, estrategias metodológicas, recursos, bibliografía.
- EFEMÉRIDES: integrás las fechas conmemorativas del calendario escolar bonaerense en las unidades didácticas como oportunidades de enseñanza transversal. Efemérides clave 2026: 24 de marzo (Día de la Memoria), 2 de abril (Malvinas), 1° de mayo (Día del Trabajador/a), 25 de mayo (Revolución de Mayo), 20 de junio (Bandera), 9 de julio (Independencia), 26 de julio (Muerte de Eva Perón), 17 de agosto (San Martín), 11 de septiembre (Maestros/as - Sarmiento), 12 de octubre (Diversidad Cultural), 20 de noviembre (Día de la Soberanía/Derechos del Niño).
- Articulación con el DC (Diseño Curricular) jurisdiccional y los NAP.
- Organización en cuatrimestres (1° cuatrimestre: marzo-julio, 2° cuatrimestre: agosto-diciembre).

PLANIFICACIÓN ANUAL DOCENTE:
- Encabezado completo: escuela, año, materia, curso, docente, turno, ciclo lectivo.
- Diagnóstico inicial del grupo.
- Propósitos del docente y objetivos de aprendizaje.
- Contenidos secuenciados por unidad/bloque/cuatrimestre.
- Estrategias metodológicas y recursos.
- Cronograma tentativo articulado con el CAD 2026 (190 días, inicio 2 marzo, receso 20-31 julio, cierre 22 diciembre).
- Bibliografía docente y para estudiantes.
- Firma y fecha.

PLAN DE EVALUACIÓN:
- Marco normativo: la evaluación como proceso continuo, formativo e integral (Res.587/11 y DC jurisdiccional). La evaluación es diagnóstica (inicio), formativa (proceso) y sumativa (acreditación).
- CRITERIOS DE EVALUACIÓN — organizados en tres dimensiones:
  • DIMENSIÓN CONCEPTUAL: comprensión y apropiación de conceptos propios del campo disciplinar; manejo de terminología específica; establecimiento de relaciones entre ideas; contextualización histórica, social y cultural; capacidad de definir, explicar y fundamentar.
  • DIMENSIÓN PROCEDIMENTAL: resolución de situaciones problemáticas; producción escrita (coherencia, cohesión, adecuación al género); análisis e interpretación de fuentes, textos, datos o imágenes; aplicación de procedimientos propios de la disciplina; comprensión lectora; pensamiento crítico y argumentación.
  • DIMENSIÓN ACTITUDINAL: participación activa y pertinente en clase; trabajo colaborativo y responsabilidad grupal; cumplimiento de plazos y acuerdos; respeto por los pares y el espacio de aprendizaje; autonomía y disposición para revisar el propio proceso.
  Cada criterio es: OBSERVABLE (qué se ve, lee o escucha), COMUNICABLE (se comparte con estudiantes y familias antes de cada instancia) y GRADABLE (con indicadores de nivel de logro).
- RÚBRICAS: construís rúbricas analíticas con 4 niveles articulados con los criterios — En inicio (1-3) / En proceso (4-6) / Alcanzado (7-8) / Destacado (9-10). Incluís descriptores concretos por nivel.
- Instrumentos de evaluación: exámenes escritos con consignas graduadas, portafolios de proceso, trabajos prácticos individuales y grupales, exposiciones orales, proyectos integradores, rúbricas analíticas, listas de cotejo, autoevaluación y coevaluación.
- Nota mínima de acreditación: 7 (siete). Los cuatrimestres NO se promedian. Nota 1 a 6 = no acreditado en ese cuatrimestre.
- Criterios de acreditación y promoción: comunicados por escrito al inicio del ciclo lectivo, disponibles en el cuaderno de comunicados y/o carpeta del estudiante.
- Comunicación a familias y estudiantes: presentación en reunión de inicio de año, boletín de notas con devolución formativa, instancias de consulta y recuperación.
- Intensificación y acreditación pendiente: hasta 5 materias (FORTE, Res.2624/25). Modalidad de examen de diciembre/marzo/julio.

AGENDA INTEGRADA (cuando te piden "agenda del miércoles", "agenda del miercoles", "agenda esto para el miércoles", "agenda esto para el miercoles", "quiero agregar el plan de evaluación", "quiero agregar el plan de evaluacion", "con criterios de evaluación", "con criterios de evaluacion", "criterios de evaluación", "criterios de evaluacion", "pcp con efemérides, planificación anual", "pcp con efemerides, planificacion anual", "pcp con efemerides, planificacion anual docente", "pcp con efemérides, planificación anual docente", "pcp con efemerides", o cualquier combinación de PCP + planificación anual + evaluación):
- Generás en un solo documento estructurado con tres secciones bien diferenciadas:
  1) PCP con efemérides: fundamentación + unidades didácticas con fechas conmemorativas integradas como ejes transversales.
  2) Planificación Anual Docente completa: encabezado, diagnóstico, propósitos, contenidos por cuatrimestre, estrategias, cronograma CAD 2026, bibliografía.
  3) Plan de Evaluación con criterios de evaluación: criterios organizados por dimensión (conceptual/procedimental/actitudinal), cada criterio con indicadores de logro observables, comunicables y graduables; instrumentos de evaluación; rúbricas analíticas con 4 niveles (En inicio 1-3 / En proceso 4-6 / Alcanzado 7-8 / Destacado 9-10); nota mínima 7; acreditación y comunicación escrita a familias y estudiantes.
- Pedís al principio: materia, curso, año, turno, docente. Si no los tienen, usás datos de ejemplo realistas.
- Formato listo para imprimir: encabezado institucional, índice, separadores claros entre secciones, numeración de páginas.

Cuando te piden generar documentos los hacés completos, listos para imprimir. Pedí los datos que necesitás (materia, curso, año, turno, docente). Formato institucional DGCyE.`,
};

const STARTERS = {
  consultas:   ["¿Cuáles son los estados administrativos obligatorios?","¿Qué es el CITE?","¿Cómo funciona la intensificación?"],
  escritos:    ["Generá un Proyecto de Supervisión del Director/a","Generá un Plan de Prevención de Riesgo","Nota formal a Inspección sobre ausentismo docente"],
  conflictos:  ["Video de un alumno se viralizó en redes","Docente no cumple sus funciones","Conflicto entre familias y preceptora"],
  criterio:    ["¿Cómo actúo ante un docente que no acepta una indicación?","Un padre amenaza con ir a la prensa. ¿Qué hago?","¿Cuándo corresponde no abrir un acto público?"],
  archivos:    ["Subí un acta para revisar","Analizá este documento","Corregí errores normativos en este texto"],
  equipo:      ["¿Cómo instruyo una leve probanza?","¿Qué hace el EDTE?","Funciones del jefe de preceptores"],
  estudiantes: ["¿Qué pasa si un alumno llega a TED?","Derechos del Centro de Estudiantes","Alumno con conductas autolesivas"],
  docente:     ["Agenda esto para el miercoles, pcp con efemerides, planificacion anual docente, quiero agregar el plan de evaluacion, con criterios de evaluacion","Hacé un PCP con efemérides integradas en las unidades didácticas","Generá una planificación anual docente completa","Creá un plan de evaluación con criterios por dimensión y rúbricas"],
};

function Dots() {
  return React.createElement('div', {style:{display:"flex",gap:4,padding:"10px 14px",background:"#f2f4f7",borderRadius:14,alignSelf:"flex-start",alignItems:"center"}},
    [0,1,2].map(i => React.createElement('div', {key:i, className:"dot", style:{animationDelay:`${i*0.2}s`}}))
  );
}

function ApiKeyScreen({onSave}) {
  const [key, setKey] = useState('');
  return React.createElement('div', {style:{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",height:"100vh",padding:24,maxWidth:480,margin:"0 auto"}},
    React.createElement('div', {style:{fontSize:36,marginBottom:16}}, "🔑"),
    React.createElement('div', {style:{fontSize:16,fontWeight:700,marginBottom:8,textAlign:"center"}}, "Ingresá tu API Key de Anthropic"),
    React.createElement('p', {style:{fontSize:13,color:"#888",textAlign:"center",marginBottom:20,lineHeight:1.5}},
      "Necesitás una API Key para usar el asistente. Se guarda solo en tu navegador y no se comparte con nadie."
    ),
    React.createElement('input', {
      type:"password", value:key, onChange:e=>setKey(e.target.value),
      placeholder:"sk-ant-api...",
      style:{width:"100%",padding:"10px 12px",border:"1px solid #ddd",borderRadius:10,fontSize:13,outline:"none",marginBottom:12}
    }),
    React.createElement('button', {
      onClick:()=>{ if(key.trim().startsWith('sk-')) { localStorage.setItem('anthropic_key', key.trim()); onSave(key.trim()); } else { alert('La key debe empezar con sk-ant-api'); }},
      style:{width:"100%",padding:14,background:"#185FA5",color:"#fff",border:"none",borderRadius:12,fontSize:13,fontWeight:700,cursor:"pointer"}
    }, "Guardar y continuar"),
    React.createElement('p', {style:{fontSize:11,color:"#bbb",marginTop:12,textAlign:"center"}},
      "Conseguí tu key en console.anthropic.com"
    )
  );
}

function App() {
  const [apiKey, setApiKey] = useState(()=>localStorage.getItem('anthropic_key')||'');
  const [tab, setTab]         = useState("consultas");
  const [screen, setScreen]   = useState("chat");
  const [chats, setChats]     = useState({consultas:[],escritos:[],conflictos:[],criterio:[],archivos:[],equipo:[],estudiantes:[],docente:[]});
  const [input, setInput]     = useState("");
  const [loading, setLoading] = useState(false);
  const [imgPrev, setImgPrev] = useState(null);
  const [imgData, setImgData] = useState(null);
  const [attached, setAttached] = useState(null);
  const [logo, setLogo]       = useState(()=>localStorage.getItem('school_logo')||null);
  const [school, setSchool]   = useState(()=>localStorage.getItem('school_name')||'');
  const [role, setRole]       = useState(null);

  const bottomRef = useRef(null);
  const camRef    = useRef(null);
  const attRef    = useRef(null);
  const logoRef   = useRef(null);
  const txtRef    = useRef(null);

  const msgs = chats[tab];
  const ac   = COLORS[tab];

  useEffect(()=>{ bottomRef.current?.scrollIntoView({behavior:"smooth"}); },[msgs,loading]);

  if(!apiKey) return React.createElement(ApiKeyScreen, {onSave:setApiKey});

  const handleImg = e => {
    const f=e.target.files[0]; if(!f) return;
    const r=new FileReader();
    r.onload=ev=>{ setImgData(ev.target.result.split(",")[1]); setImgPrev(ev.target.result); };
    r.readAsDataURL(f); e.target.value="";
  };

  const handleAttach = e => {
    const f=e.target.files[0]; if(!f) return;
    const r=new FileReader();
    const isImg=f.type.startsWith("image/");
    r.onload=ev=>setAttached({data:ev.target.result.split(",")[1],type:isImg?"image":f.type==="application/pdf"?"pdf":"text",name:f.name,prev:isImg?ev.target.result:null,mime:f.type});
    r.readAsDataURL(f); e.target.value="";
  };

  const handleLogo = e => {
    const f=e.target.files[0]; if(!f) return;
    const r=new FileReader();
    r.onload=ev=>{ setLogo(ev.target.result); localStorage.setItem('school_logo', ev.target.result); };
    r.readAsDataURL(f); e.target.value="";
  };

  const send = async () => {
    const txt=input.trim();
    if(!txt&&!imgData&&!(tab==="archivos"&&attached)) return;
    if(loading) return;
    const um={role:"user",text:txt,img:imgPrev,...(tab==="archivos"&&attached?{fd:attached.data,ft:attached.type,fn:attached.name,fm:attached.mime}:{})};
    setChats(c=>({...c,[tab]:[...c[tab],um]}));
    setInput(""); setImgData(null); setImgPrev(null);
    if(tab==="archivos") setAttached(null);
    setLoading(true);
    const hist=[...chats[tab],um];
    const apiMsgs=hist.map(m=>{
      if(m.role==="user"){
        const c=[];
        if(m.img) c.push({type:"image",source:{type:"base64",media_type:"image/jpeg",data:m.img.split(",")[1]||m.img}});
        if(m.fd){
          if(m.ft==="image") c.push({type:"image",source:{type:"base64",media_type:m.fm||"image/jpeg",data:m.fd}});
          else if(m.ft==="pdf") c.push({type:"document",source:{type:"base64",media_type:"application/pdf",data:m.fd}});
          else c.push({type:"text",text:`[Archivo: ${m.fn}]`});
        }
        if(m.text) c.push({type:"text",text:m.text});
        return {role:"user",content:c.length===1&&!m.img&&!m.fd?m.text:c};
      }
      return {role:"assistant",content:m.text};
    });
    try{
      const r=await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST",
        headers:{"Content-Type":"application/json","x-api-key":apiKey,"anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true"},
        body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:tab==="docente"?8000:1500,system:PROMPTS[tab],messages:apiMsgs})
      });
      const d=await r.json();
      const txt2=d.content?.[0]?.text || (d.error ? `Error: ${d.error.message}` : "Sin respuesta.");
      setChats(c=>({...c,[tab]:[...c[tab],{role:"assistant",text:txt2}]}));
    }catch(e){
      setChats(c=>({...c,[tab]:[...c[tab],{role:"assistant",text:"Error de conexión. Verificá tu API key."}]}));
    }
    setLoading(false);
  };

  const hKey=e=>{ if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();send();} };

  const exportWord = txt => {
    const body=txt.replace(/\n\n/g,"</p><p>").replace(/\n/g,"<br>");
    let hdr="";
    if(logo) hdr+=`<img src="${logo}" style="height:52px;display:block;margin:0 auto 6px;object-fit:contain">`;
    if(school) hdr+=`<p style="text-align:center;font-weight:bold;font-size:13pt;margin:0 0 8pt">${school}</p>`;
    const html=`<html xmlns:o='urn:schemas-microsoft-com:office:office'><head><meta charset='utf-8'><style>body{font-family:Arial;font-size:11pt;line-height:1.6;margin:2.5cm}p{margin:0 0 6pt}</style></head><body>${hdr}<p>${body}</p></body></html>`;
    const a=document.createElement("a");a.href=URL.createObjectURL(new Blob(["\ufeff",html],{type:"application/msword"}));a.download="documento.doc";a.click();
  };

  // SETTINGS SCREEN
  if(screen==="settings") return React.createElement('div', {style:{display:"flex",flexDirection:"column",height:"100vh",maxWidth:480,margin:"0 auto"}},
    React.createElement('div', {style:{padding:"12px 16px",borderBottom:"1px solid #eee",display:"flex",alignItems:"center",gap:12,flexShrink:0}},
      React.createElement('button', {onClick:()=>setScreen("chat"),style:{background:"none",border:"none",fontSize:22,cursor:"pointer",color:"#888"}}, "‹"),
      React.createElement('div', {style:{fontSize:13,fontWeight:700}}, "Configuración institucional")
    ),
    React.createElement('div', {style:{flex:1,overflowY:"auto",padding:"20px 16px",display:"flex",flexDirection:"column",gap:18}},
      React.createElement('div', null,
        React.createElement('div', {style:{fontSize:12,fontWeight:700,color:"#555",marginBottom:10}}, "Logo de la escuela"),
        React.createElement('div', {style:{display:"flex",alignItems:"center",gap:14}},
          React.createElement('div', {onClick:()=>logoRef.current?.click(),style:{width:80,height:80,borderRadius:10,border:"1px dashed #ccc",display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",overflow:"hidden",background:"#f8f8f8",flexShrink:0,fontSize:28}},
            logo ? React.createElement('img',{src:logo,style:{width:"100%",height:"100%",objectFit:"contain"},alt:""}) : "🖼️"
          ),
          React.createElement('div', null,
            React.createElement('p', {style:{fontSize:12,color:"#666",lineHeight:1.5,marginBottom:8}}, "El logo se incluye en documentos Word."),
            React.createElement('div', {style:{display:"flex",gap:8}},
              React.createElement('button', {onClick:()=>logoRef.current?.click(),style:{padding:"6px 14px",background:"#f0f0f0",border:"1px solid #ddd",borderRadius:8,fontSize:12,cursor:"pointer"}}, logo?"Cambiar":"Subir logo"),
              logo && React.createElement('button', {onClick:()=>{setLogo(null);localStorage.removeItem('school_logo');},style:{padding:"6px 14px",background:"none",border:"1px solid #ffcccc",borderRadius:8,fontSize:12,cursor:"pointer",color:"#A32D2D"}}, "Quitar")
            )
          )
        ),
        React.createElement('input', {ref:logoRef,type:"file",accept:"image/*",onChange:handleLogo,style:{display:"none"}})
      ),
      React.createElement('div', null,
        React.createElement('label', {style:{fontSize:12,fontWeight:700,color:"#555",display:"block",marginBottom:8}}, "Nombre de la escuela"),
        React.createElement('input', {value:school,onChange:e=>setSchool(e.target.value),placeholder:"Ej: E.E.S. N° 23 — San Miguel",
          style:{width:"100%",padding:"10px 12px",border:"1px solid #ddd",borderRadius:10,fontSize:13,outline:"none"}})
      ),
      React.createElement('div', null,
        React.createElement('label', {style:{fontSize:12,fontWeight:700,color:"#555",display:"block",marginBottom:8}}, "API Key de Anthropic"),
        React.createElement('input', {value:apiKey,onChange:e=>setApiKey(e.target.value),type:"password",placeholder:"sk-ant-api...",
          style:{width:"100%",padding:"10px 12px",border:"1px solid #ddd",borderRadius:10,fontSize:13,outline:"none"}}),
        React.createElement('div', {style:{fontSize:11,color:"#aaa",marginTop:4}}, "console.anthropic.com")
      ),
      React.createElement('button', {onClick:()=>{localStorage.setItem('school_name',school);localStorage.setItem('anthropic_key',apiKey);setScreen("chat");},
        style:{padding:14,background:"#185FA5",color:"#fff",border:"none",borderRadius:12,fontSize:13,fontWeight:700,cursor:"pointer"}}, "Guardar y volver")
    )
  );

